# Definizione delle stanze, oggetti, eventi

{
  "start_room": "entrance",


  "rooms": {
    "entrance": {
      "name_key": "room.entrance.name",
      "description_key": "room.entrance.description",
      "exits": {
        "north": "dining_room",
        "south": "master_bedroom",
        "east": "kitchen"
      }
      "objects": ["entrance_door","decorations", "tapestry","master_door", "Merlin", "Kilgharrah"]
    },

    "dining_room": {
      "name_key": "room.dining.name",
      "description_key": "room.dining.description",
      "exits": {
        "south": "entrance",
        "east": "north_hallway"
      }
      "objects": ["fireplace_on", "round_table", "decorations", "library_key"]
    },

    "north_hallway": {
      "name_key": "room.north.hallway.name",
      "description_key": "room.north.hallway.description",
      "exits": {
        "west": "dining_room",
        "east": "2nd_bedroom",
        "south": "main_hallway"
        }
      "objects": ["bedroom_door"]
    },

    "main_hallway": {
      "name_key": "room.main.hallway.name",
      "description_key": "room.main.hallway.description",
      "exits": {
        "west": "kitchen",
        "south": "south_hallway",
        "south_east": "library",
        "east": "east_hallway",
        "north": "north_hallway"
        }
      "objects": ["library_door"]
      },

    "bathroom": {
      "name_key": "room.bathroom.name",
      "description_key": "room.bathroom.description",
      "exits": {
         "east": "south_hallway"
        }
      "objects": ["bathtub", "mirror"]
      },

    "master_bedroom": {
      "name_key": "room.master.bedroom.name",
      "description_key": "room.master.bedroom.description",
      "exits": {
         "north": "entrance",
         "east": "south_hallway"
        }
      "objects": ["bed", "closet", "fireplace_off", "desk_1", "bedroom_key"]
      },
        
    "south_hallway": {
      "name_key": "room.south.hallway.name",
      "description_key": "room.south.hallway.description",
      "exits": {
         "north": "main_hallway",
         "west": "master_bedroom",
         "north_west": "bathroom"
        }
      
      },
        
    "library": {
      "name_key": "room.library.name",
      "description_key": "room.library.description",
      "exits": {
         "north": "secret_room",
         "west": "main_hallway"
        }
      "objects": ["tables_l", "bookshelves", "secret_door"]
      },

    "secret_room": {
      "name_key": "room.secret.name",
      "description_key": "room.secret.description",
      "exits": {
         "south": "library"
        }
      "objects": ["Arthur", "flower", "exit_key"]
      },

     "kitchen": {
      "name_key": "room.kitchen.name",
      "description_key": "room.kitchen.description",
      "exits": {
         "east": "main_hallway"
        }
      "objects": ["stove", "tables_k","Excalibur", "bucket"]
      },

    "east_hallway": {
      "name_key": "room.east.hallway.name",
      "description_key": "room.east.hallway.description",
      "exits": {
         "north": "2nd_bedroom",
         "out": "final_exit",
         "west": "main_hallway"
        }
      "objects": ["bedroom_exit", "exit_door"]
      },

    "2nd_bedroom": {
       "name_key": "room.bedroom.name",
      "description_key": "room.bedroom.description",
      "exits": {
         "west": "north_hallway",
         "south": "east_hallway"
        }
      "objects": ["beds", "desk_2", "books", "magic_book"]
      },
      

    "final_exit": {
      "name_key": "room.final.exit.name",
      "description_key": "room.final.exit.description",
      "exits": {}
    }
  }
}   
