# Definizione delle stanze, oggetti, eventi

{
  "start_room": "entrance",


  "rooms": {
    "entrance": {
      "name_key": "room.entrance.name",
      "description_key": "room.entrance.description",
      "exits": {
        "north": "dining_room",
        "south": "master_bedroom",
        "east": "kitchen"
      }
      
    },

    "dining_room": {
      "name_key": "room.dining.name",
      "description_key": "room.dining.description",
      "exits": {
        "south": "entrance",
        "east": "north_hallway"
      }
    },

    "north_hallway": {
      "name_key": "room.north.hallway.name",
      "description_key": "room.north.hallway.description",
      "exits": {
        "east": "2nd_bedroom",
        "south": "main_hallway"
        }
    },

    "main_hallway": {
      "name_key": "room.main.hallway.name",
      "description_key": "room.main.hallway.description",
      "exits": {
        "west": "kitchen",
        "south_west": "bathroom",
        "south": "south_hallway",
        "south_east": "library",
        "east": "east_hallway",
        "north_east": "2nd_bedroom",
        "north": "north_hallway"
        }
      },

    "bathroom": {
      "name_key": "room.bathroom.name",
      "description_key": "room.bathroom.description",
      "exits": {
         "west": "main_hallway"
        }
      },

    "master_bedroom": {
      "name_key": "room.master.bedroom.name",
      "description_key": "room.master.bedroom.description",
      "exits": {
         "north": "entrance",
         "east": "south_hallway"
        }
      },
        
    "south_hallway": {
      "name_key": "room.south.hallway.name",
      "description_key": "room.south.hallway.description",
      "exits": {
         "north": "main_hallway"
        }
      },
        
    "library": {
      "name_key": "room.library.name",
      "description_key": "room.library.description",
      "exits": {
         "north_east": "secret_room",
         "west": "main_hallway"
        }
      },

    "secret_room": {
      "name_key": "room.secret.name",
      "description_key": "room.secret.description",
      "exits": {
         "south": "library"
        }
      },

    "east_hallway": {
      "name_key": "room.east.hallway.name",
      "description_key": "room.east.hallway.description",
      "exits": {
         "north": "2nd_bedroom",
         "out": "final_exit"
        }
      },

    "2nd_bedroom": {
       "name_key": "room.2nd.bedroom.name",
      "description_key": "room.2nd.bedroom.description",
      "exits": {
         "west": "north_hallway",
         "south": "main_hallway"
        }
      },
      

    "final_exit": {
      "name_key": "room.final.exit.name",
      "description_key": "room.final.exit.description",
      "exits": {}
    }
  }
}   
