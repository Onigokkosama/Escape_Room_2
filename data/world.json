# Definizione delle stanze, oggetti, eventi

{
  "start_room": "entrance",


  "rooms": {
    "entrance": {
      "name_key": "room.entrance.name",
      "description_key": {
        "first": "room.entrance.first.description",
        "default": "room.entrance.revisit.description",
        "condition": {
          "if": "tapestry_moved",
          "key": "room.entrance.conditional.description"
        }
      }
    },
      "exits": {
        "north": {
          "to": "dining_room",
          "aliases": {
             "en": ["big door", "double door", "big", "bigger"],
             "it": ["porta grande", "porta a doppio battente", "grande"]
          }
        },
        "south": {
          "to": "master_bedroom",
          "blocked_by": "tapestry"
        },
        "east": {
          "to": "kitchen",
          "aliases": {
             "en": ["small door", "small", "smaller"],
             "it": ["porta piccola", "piccola"]
          }
        },
      }
      "objects": ["front_door", "decorations", "tapestry","master_door", "Merlin", "Kilgharrah"]
    },

    "dining_room": {
      "name_key": "room.dining.name",
      "description_key": {
        "first": "room.dining.first.description",
        "default": "room.dining.revisit.description",
        "condition": {
          "if": "fireplace_off",
          "key": "room.dining.conditional.description"
        }  
      },
      "exits": {
        "south": {
          "to":  "entrance",
          "aliases": {
             "en": ["big door", "double door", "big", "bigger"],
             "it": ["porta grande", "porta a doppio battente", "grande"] 
          }
        },
        "east": {
          "to": "north_hallway",
          "aliases": {
            "en": ["small door", "decorated door", "small", "smaller", "decorated"],
            "it": ["porta piccola", "porta decorata", "più piccola", "decorata"] 
          }
        }
      },
      "objects": ["fireplace_on", "fireplace_off", "round_table", "decorations", "library_key"]
    },

    "north_hallway": {
      "name_key": "room.north.hallway.name",
      "description_key": "room.north.hallway.description",
      "exits": {
        "west": {
          "to": "dining_room",
          "aliases": {
            "en": ["small door", "decorated door", "wooden door", "wood door", "small", "smaller", "decorated"],
            "it": ["porta piccola", "porta decorata", "porta di legno", "più piccola", "decorata", "di legno"] 
          }
        },
        "east": {
          "to":"2nd_bedroom",
          "door": "bedroom_door",
          "requires": "bedroom_key",
          "aliases": {
            "en": ["pointed arch door", "pointed", "arch", "arched"],
            "it": ["porta con arco a sesto acuto", "arcuata", "ad arco"]
          }
        },
        "south": {
          "to": "main_hallway",
          "aliases": {
            "en": ["other hallway", "longer hallway", "longer", "hallway"],
            "it": ["altro corridoio", "corridoio più lungo", "lungo", "corridoio"]
          }
        }
      },
        
      "objects": ["bedroom_door"]
    },

    "main_hallway": {
      "name_key": "room.main.hallway.name",
      "description_key": "room.main.hallway.description",
      "exits": {
        "west": "kitchen",
        "south": "south_hallway",
        "south_east": {
            "to": "library",
            "door": "library_door",
            "requires": "library_key" },
        "east": "east_hallway",
        "north": "north_hallway"
        }
      "objects": ["library_door"]
      },

    "bathroom": {
      "name_key": "room.bathroom.name",
      "description_key": "room.bathroom.description",
      "exits": {
         "south": "south_hallway"
        }
      "objects": ["bathtub", "mirror"]
      },

    "master_bedroom": {
      "name_key": "room.master.bedroom.name",
      "description_key": "room.master.bedroom.description",
      "exits": {
         "north": {
           "to": "entrance",
           "aliases": {
             "en": ["tapestry"],
             "it": ["arazzo"]
           }
         },
         "east": {
           "to": "south_hallway",
           "aliases": {
             "en": ["small door", "wooden door", "wooden", "inconspicuous", "servants door", "door"],
             "it": ["porta di legno", "servitù", "nascosta", "piccola", "porta"]
           }
         }
        }
      "objects": ["bed", "chess_set", "closet", "desk_1", "parchment", "bedroom_key"]
    },
        
    "south_hallway": {
      "name_key": "room.south.hallway.name",
      "description_key": "room.south.hallway.description",
      "exits": {
         "north": "main_hallway",
         "west": "master_bedroom",
         "north_west": "bathroom"
        }
      
      },
        
    "library": {
      "name_key": "room.library.name",
      "description_key": "room.library.description",
      "exits": {
         "north": {
           "to":"secret_room",
           "blocked_by": "bookshelf",
           "requires":"magic_book",
         },
         "west": "main_hallway"
        }
      "objects": ["tables_l", "bookshelf"]
      },

    "secret_room": {
      "name_key": "room.secret.name",
      "description_key": "room.secret.description",
      "exits": {
         "south": "library"
        }
      "objects": ["Arthur", "flower", "exit_key"]
      },

     "kitchen": {
      "name_key": "room.kitchen.name",
      "description_key": {
        "first": "room.kitchen.description",
        "condition": {
          "if": "Excalibur_taken",
          "key": "room.kitchen.swordless.description"
        }
      },
      "exits": {
         "east": {
           "to": "main_hallway",
           "aliases": {
             "en": ["bigger door", "bigger", "decorated door", "decorated", "stained glass door"],
             "it": ["porta grande", "più grande", "grande", "decorata", "porta col vetro", "vetro decorato"]
           }
         }, 
        "west": {
          "to": "entrance",
          "aliases": {
            "en": ["small door", "small", "smaller"],
            "it": ["porta piccola", "piccola"]
          }
        }
      },
      "objects": ["sink", "tables_k","Excalibur", "bucket"]
    },

    "east_hallway": {
      "name_key": "room.east.hallway.name",
      "description_key": "room.east.hallway.description",
      "exits": {
         "north": "2nd_bedroom",
         "out": {
           "to":"final_exit",
           "door": "exit_door",
           "requires": "exit_key" },
         "west": "main_hallway"
        }
      "objects": ["bedroom_exit", "exit_door"]
      },

    "2nd_bedroom": {
       "name_key": "room.bedroom.name",
      "description_key": "room.bedroom.description",
      "exits": {
         "west": "north_hallway",
         "south": "east_hallway"
        }
      "objects": ["beds", "desk_2", "books", "magic_book"]
      },
      

    "final_exit": {
      "name_key": "room.final.exit.name",
      "description_key": "room.final.exit.description",
      "exits": { }
    }
  }
}   
